{
  "expo": {
    "name": "티키타카",
    "slug": "TikiTaka",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/tikitaka-logo.png",
    "scheme": "tikitaka",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/tikitaka-bg-white.png",
      "bundleIdentifier": "com.anonymous.TikiTaka"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/tikitaka-logo.png",
        "backgroundImage": "./assets/images/android-icon-background.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": ["android.permission.CAMERA", "android.permission.RECORD_AUDIO"],
      "package": "com.anonymous.TikiTaka"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/tikitaka-bg-white.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "android": {
            "image": "./assets/images/tikitaka-logo.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Pretendard-Regular.ttf",
            "./assets/fonts/Pretendard-Medium.ttf",
            "./assets/fonts/Pretendard-Bold.ttf",
            "./assets/fonts/OkDanDan-Bold.ttf"
          ]
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "동네 사진을 촬영하기 위해 카메라 접근 권한이 필요합니다."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
